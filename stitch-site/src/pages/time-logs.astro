<script>
        // Simple micro-interaction for the dispatch button
        const dispatchBtn = document.querySelector('button.bg-secondary.text-on-secondary');
        if (dispatchBtn) {
            dispatchBtn.addEventListener('click', () => {
                dispatchBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Processing...';
                setTimeout(() => {
                    dispatchBtn.innerHTML = '<span class="material-symbols-outlined">check_circle</span> SUCCESS';
                    dispatchBtn.classList.remove('bg-secondary');
                    dispatchBtn.classList.add('bg-green-600');
                }, 1500);
            });
        }

        // Tonal layering hover effect for tech list
        const techItems = document.querySelectorAll('.max-h-\\[320px\\] > div');
        techItems.forEach(item => {
            item.addEventListener('mouseenter', () => {
                if(!item.classList.contains('border-secondary')) {
                    item.style.borderColor = '#adc6ff';
                }
            });
            item.addEventListener('mouseleave', () => {
                if(!item.classList.contains('border-secondary')) {
                    item.style.borderColor = '#c6c6cd';
                }
            });
        });
    </script>


</body></html>