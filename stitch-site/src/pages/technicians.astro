<div class="p-lg space-y-lg">
<div class="grid grid-cols-2 gap-md">
<div class="p-md bg-surface-container-low rounded-xl border border-outline-variant">
<p class="text-label-caps font-label-caps text-on-surface-variant mb-xs">UNIQUE USERNAME</p>
<p class="font-data-mono text-data-mono text-secondary text-lg" id="genUsername">@m_finn_29</p>
</div>
<div class="p-md bg-surface-container-low rounded-xl border border-outline-variant">
<p class="text-label-caps font-label-caps text-on-surface-variant mb-xs">TEMPORARY PASSWORD</p>
<div class="flex justify-between items-center">
<p class="font-data-mono text-data-mono text-on-surface text-lg tracking-wider" id="genPassword">LF-772-XT9</p>
<button class="text-secondary hover:underline text-body-sm font-bold">Show</button>
</div>
</div>
</div>
<div class="space-y-sm">
<label class="font-label-caps text-label-caps text-on-surface-variant">INVITATION PREVIEW</label>
<div class="p-md bg-surface border border-outline-variant rounded-lg text-body-sm text-on-surface-variant italic leading-relaxed">
                        "Welcome to LogiFlow, <span class="not-italic font-bold text-on-surface">Michael Finn</span>! Your dispatcher account is ready. Username: @m_finn_29 | Temp Pass: LF-772-XT9. Please login at fleet.logiflow.io/app to start your shift."
                    </div>
</div>
<div class="flex flex-col gap-sm">
<p class="text-label-caps font-label-caps text-on-surface-variant text-center">SHARE CREDENTIALS VIA</p>
<div class="grid grid-cols-3 gap-sm">
<button class="flex flex-col items-center gap-xs p-md border border-outline-variant rounded-xl hover:bg-surface-container-low transition-all">
<span class="material-symbols-outlined text-secondary">sms</span>
<span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">SMS</span>
</button>
<button class="flex flex-col items-center gap-xs p-md border border-outline-variant rounded-xl hover:bg-surface-container-low transition-all">
<span class="material-symbols-outlined text-emerald-600">chat</span>
<span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">WhatsApp</span>
</button>
<button class="flex flex-col items-center gap-xs p-md border border-outline-variant rounded-xl hover:bg-surface-container-low transition-all" onclick="copyToClipboard()">
<span class="material-symbols-outlined text-on-surface">content_copy</span>
<span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Copy</span>
</button>
</div>
</div>
<button class="w-full py-sm border border-outline-variant rounded-lg font-bold hover:bg-surface-container-low transition-colors" onclick="closeModal()">Done, Return to Dashboard</button>
</div>
</div>
</div>
<script>
        function openModal() {
            document.getElementById('registrationModal').classList.remove('hidden');
            document.getElementById('formView').classList.remove('hidden');
            document.getElementById('successView').classList.add('hidden');
        }

        function closeModal() {
            document.getElementById('registrationModal').classList.add('hidden');
            document.getElementById('techForm').reset();
        }

        function handleRegistration(event) {
            event.preventDefault();
            const name = document.getElementById('fullName').value;
            
            // Artificial delay for feedback
            const submitBtn = event.target.querySelector('button[type="submit"]');
            submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Creating...';
            submitBtn.disabled = true;

            setTimeout(() => {
                document.getElementById('displayTechName').innerText = name;
                document.getElementById('genUsername').innerText = `@${name.toLowerCase().replace(/\s+/g, '_')}_${Math.floor(Math.random() * 99)}`;
                
                document.getElementById('formView').classList.add('hidden');
                document.getElementById('successView').classList.remove('hidden');
                
                submitBtn.innerHTML = 'Create Profile';
                submitBtn.disabled = false;
            }, 800);
        }

        function copyToClipboard() {
            // Mock feedback
            const copyBtn = event.currentTarget;
            const originalHtml = copyBtn.innerHTML;
            copyBtn.innerHTML = '<span class="material-symbols-outlined text-emerald-500">done</span><span class="text-[10px] font-bold uppercase tracking-widest text-emerald-500">Copied</span>';
            setTimeout(() => { copyBtn.innerHTML = originalHtml; }, 2000);
        }

        // Close on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });
    </script>


</body></html>